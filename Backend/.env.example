# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to git!
# ─────────────────────────────────────────────

# ── Database ─────────────────────────────────
POSTGRES_DB=restate
POSTGRES_USER=restate_user
POSTGRES_PASSWORD=your_strong_db_password_here

# ── Redis ─────────────────────────────────────
REDIS_PASSWORD=your_strong_redis_password_here

# ── JWT ───────────────────────────────────────
# Generate a secure 256-bit+ base64 secret, e.g.:
#   openssl rand -base64 64
SECRET_KEY=your_jwt_secret_key_here

# ── Email (Gmail SMTP) ────────────────────────
EMAIL=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# ── Google OAuth ──────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ── Frontend ──────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Cloudinary ────────────────────────────────
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_KEY=your_cloudinary_api_key
CLOUD_SECRET=your_cloudinary_api_secret

# ── Firebase ──────────────────────────────────
VAPID_KEY=your_firebase_vapid_key_here
# Paste the entire contents of your firebase-service-account.json as a single-line JSON string.
# TIP: On Linux/Mac: FIREBASE_CONFIG_JSON=$(cat src/main/resources/firebase-service-account.json | tr -d '\n')
FIREBASE_CONFIG_JSON={"type":"service_account","project_id":"..."}
